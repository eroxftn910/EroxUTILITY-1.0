<Window x:Class="EroxUTILITY.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E-TWEAKS"
        Width="980"
        Height="610"
        WindowStartupLocation="CenterScreen"
        Background="#303030">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="68"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#2B2B2B" BorderBrush="#3A3A3A" BorderThickness="0,0,1,0">
            <Grid>
                <StackPanel>
                    <TextBlock Text="›"
                               Foreground="White"
                               FontSize="30"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,16"/>

                    <!-- MAISON -->
                    <Button Content="⌂"
                            Height="56"
                            Margin="6"
                            FontSize="22"
                            Background="#4A392E"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ShowHome"/>

                    <!-- WINDOWS -->
                    <Button Content="▦"
                            Height="46"
                            Margin="6"
                            FontSize="20"
                            Background="#2B2B2B"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ShowWindows"/>

                    <!-- JEUX -->
                    <Button Content="🎮"
                            Height="46"
                            Margin="6"
                            FontSize="18"
                            Background="#2B2B2B"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ShowGames"/>

                    <!-- POWERPLAN -->
                    <Button Content="⚡"
                            Height="46"
                            Margin="6"
                            FontSize="18"
                            Background="#2B2B2B"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ShowPower"/>

                    <!-- SERVICES -->
                    <Button Content="⚙"
                            Height="46"
                            Margin="6"
                            FontSize="20"
                            Background="#2B2B2B"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ShowServices"/>

                    <!-- GPU -->
                    <Button Content="🌐"
                            Height="46"
                            Margin="6"
                            FontSize="18"
                            Background="#2B2B2B"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ShowGPU"/>
                </StackPanel>

                <Button Content="☰"
                        Height="46"
                        Margin="6"
                        FontSize="20"
                        Background="#2B2B2B"
                        Foreground="White"
                        BorderThickness="0"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="90"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="82"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <StackPanel Grid.Row="0">
                <TextBlock FontSize="25" FontWeight="Bold">
                    <Run x:Name="PageTitle" Text="Bienvenue sur " Foreground="White"/>
                    <Run x:Name="AccentTitle" Text="E-TWEAKS" Foreground="#E87522"/>
                </TextBlock>

                <TextBlock x:Name="PageSubtitle"
                           Text="Accès rapide à vos outils système"
                           Foreground="#BEBEBE"
                           FontSize="13"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <!-- REPAIR CARD -->
            <Border Grid.Row="1"
                    Margin="0,20,0,10"
                    Background="#493A31"
                    BorderBrush="#70451F"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="42"
                            Height="42"
                            Background="#6A3C22"
                            CornerRadius="12">
                        <TextBlock Text="🛡️"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Réparation système"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold"/>

                        <TextBlock Text="SFC, DISM, DNS, Winsock — actions de réparation rapide"
                                   Foreground="#D0D0D0"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="›"
                               Foreground="#E87522"
                               FontSize="26"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2"
                       Text="ACCÈS RAPIDE"
                       Foreground="#B8B8B8"
                       FontWeight="Bold"
                       FontSize="12"
                       Margin="0,14,0,12"/>

            <!-- CARDS -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="CardsLeft" Grid.Column="0"/>
                <StackPanel x:Name="CardsRight" Grid.Column="2"/>
            </Grid>

            <!-- LOGS -->
            <TextBox Grid.Row="4"
                     x:Name="LogsBox"
                     Background="#111111"
                     Foreground="#00FF55"
                     BorderBrush="#333333"
                     FontSize="11"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>
    </Grid>
</Window>
