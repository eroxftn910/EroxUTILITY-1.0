<Window x:Class="EroxUTILITY.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EroxUTILITY"
        Height="600"
        Width="1000"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- SIDEBAR -->
        <StackPanel Width="80" Background="#252526" HorizontalAlignment="Left">
            
            <TextBlock Text="Erox"
                       Foreground="Orange"
                       FontSize="18"
                       Margin="10"
                       FontWeight="Bold"/>

            <Button Content="🏠" Margin="10" Click="MenuHome"/>
            <Button Content="🪟" Margin="10" Click="MenuWindows"/>
            <Button Content="🎮" Margin="10" Click="MenuGames"/>
            <Button Content="⚡" Margin="10" Click="MenuPower"/>
            <Button Content="🔧" Margin="10" Click="MenuServices"/>
            <Button Content="🎯" Margin="10" Click="MenuGPU"/>
        </StackPanel>

        <!-- CONTENU -->
        <Grid Margin="90,10,10,10">

            <StackPanel x:Name="MainContent">

                <TextBlock Text="Bienvenue sur Erox Utility"
                           Foreground="White"
                           FontSize="28"
                           Margin="10"/>

                <TextBlock Text="Accès rapide à vos outils système"
                           Foreground="Gray"
                           Margin="10"/>

                <!-- CARDS -->
                <WrapPanel Margin="10">

                    <Border Background="#2D2D30" CornerRadius="10" Margin="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Réparation système" Foreground="White"/>
                            <TextBlock Text="SFC / DISM" Foreground="Gray"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2D2D30" CornerRadius="10" Margin="10" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Gestionnaire" Foreground="White"/>
                            <TextBlock Text="Task Manager" Foreground="Gray"/>
                        </StackPanel>
                    </Border>

                </WrapPanel>

            </StackPanel>

        </Grid>

        <!-- LOGS -->
        <TextBox x:Name="LogsBox"
                 Height="120"
                 VerticalAlignment="Bottom"
                 Background="Black"
                 Foreground="Lime"
                 TextWrapping="Wrap"
                 IsReadOnly="True"/>

    </Grid>
</Window>
