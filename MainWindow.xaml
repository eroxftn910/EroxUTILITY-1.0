<Window x:Class="EroxUTILITY.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EroxUTILITY"
        Height="560" Width="920"
        WindowStartupLocation="CenterScreen"
        Background="#2F2F2F">

    <Window.Resources>
        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Background" Value="#424242"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SideButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#252525">
            <StackPanel>
                <TextBlock Text="›" Foreground="White" FontSize="30"
                           HorizontalAlignment="Center" Margin="0,12,0,12"/>

                <Button Content="⌂" Style="{StaticResource SideButton}" Background="#3A3A3A"/>
                <Button Content="▦" Style="{StaticResource SideButton}"/>
                <Button Content="⚙" Style="{StaticResource SideButton}"/>
                <Button Content="🧹" Style="{StaticResource SideButton}"/>
                <Button Content="🌐" Style="{StaticResource SideButton}"/>

                <StackPanel VerticalAlignment="Bottom" Margin="0,210,0,0">
                    <Button Content="☰" Style="{StaticResource SideButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="84"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock FontSize="24" FontWeight="Bold">
                    <Run Text="Bienvenue sur " Foreground="White"/>
                    <Run Text="Erox Utility" Foreground="#E87522"/>
                </TextBlock>
                <TextBlock Text="Optimisation Windows rapide et propre"
                           Foreground="#BDBDBD" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Big optimization card -->
            <Button Grid.Row="1"
                    Margin="0,18,0,14"
                    Background="#4A3E35"
                    BorderBrush="#7A4A25"
                    BorderThickness="1"
                    Cursor="Hand"
                    Click="Optimize_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="38" Height="38"
                            Background="#6A3C22"
                            CornerRadius="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Optimiser mon PC en 1 clic"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Tweaks, nettoyage, optimisation Windows — lancement rapide"
                                   Foreground="#C9C9C9"
                                   FontSize="12"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="›"
                               Foreground="#D98235"
                               FontSize="24"
                               VerticalAlignment="Center"/>
                </Grid>
            </Button>

            <TextBlock Grid.Row="2"
                       Text="ACCÈS RAPIDE"
                       Foreground="#B7B7B7"
                       FontWeight="Bold"
                       FontSize="12"
                       Margin="0,8,0,12"/>

            <!-- Quick cards -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Button Style="{StaticResource CardButton}" Content="🧹  Nettoyage Windows"/>
                    <Button Style="{StaticResource CardButton}" Content="🧰  Réparation système"/>
                    <Button Style="{StaticResource CardButton}" Content="💿  Gestion des disques"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Button Style="{StaticResource CardButton}" Content="📊  Gestionnaire des tâches"/>
                    <Button Style="{StaticResource CardButton}" Content="🌐  Optimisation réseau"/>
                    <Button Style="{StaticResource CardButton}" Content="🛡  Désactiver télémétrie"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
