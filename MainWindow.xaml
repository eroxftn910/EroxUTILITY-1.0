<Window x:Class="EroxUTILITY.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EroxUTILITY" Height="600" Width="1000"
        Background="#1E1E1E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Background="#252525">
            <TextBlock Text="EroxUTILITY" Foreground="Orange" FontSize="18" Margin="10"/>

            <Button Content="🖥 Windows" Click="ShowWindows"/>
            <Button Content="🎮 Jeux" Click="ShowGames"/>
            <Button Content="⚡ PowerPlan" Click="ShowPower"/>
            <Button Content="⚙ Services" Click="ShowServices"/>
            <Button Content="🎮 GPU" Click="ShowGPU"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <Grid x:Name="MainContent"/>

            <!-- Logs -->
            <TextBox Grid.Row="1"
                     x:Name="LogBox"
                     Background="#111"
                     Foreground="Lime"
                     IsReadOnly="True"
                     TextWrapping="Wrap"/>
        </Grid>
    </Grid>
</Window>
